ENVIRONMENT=development

DB_HOST=postgres
DB_PORT=5432
DB_NAME=riverbend
DB_USER=riverbend_app
DB_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

PAYER_API_URL=https://edi.example.com/v1/eligibility
PAYER_API_KEY=changeme

HL7_FEED_HOST=hl7.example.org
HL7_FEED_PORT=2575

SESSION_SECRET=changeme

# AWS Bedrock (ai-assistant service, see ADR 0005). Copy this file to .env
# (gitignored, never tracked) and add your real Bedrock bearer API key there
# only. AWS_BEARER_TOKEN_BEDROCK is read directly by boto3/botocore — never by
# app code — so it never lands in a config object, log, or exception message.
# BEDROCK_MODEL_ID / AWS_REGION must match a model+region your Bedrock account
# can invoke (and, for real PHI, that your AWS BAA covers). Note: an older .env
# was previously committed — those values are still in git history and must be
# rotated (see docs/debt-log.md remediation runbook).
# The ai-assistant FAILS CLOSED without this key: it refuses every LLM call
# rather than fall back to ambient AWS credentials (instance role, AWS_* env).
# Shipped EMPTY on purpose so a copied example config fails closed by default —
# CI seeds .env via `cp .env.example .env`, and a non-empty placeholder (e.g.
# "changeme") would satisfy a bare presence check and let a misconfigured
# deploy egress PHI before AWS rejects the auth. Set the real bearer key in
# .env only; the guard also rejects known placeholder sentinels.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
# claude-sonnet-4-6 (the model the eval in docs/research/ recommends, ADR 0005)
# is INFERENCE_PROFILE-only on Bedrock (the bare anthropic.claude-sonnet-4-6 id
# is NOT invokable on-demand). Use a region-scoped inference profile id; verify
# the exact one for your account/region with:
#   aws bedrock list-inference-profiles --region <region>
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# The cost gate fails closed per model: a BEDROCK_MODEL_ID with no entry in
# llm_client._MODEL_PRICING refuses every call unless BOTH overrides below are
# set (USD per million tokens). Set both or neither.
# LLM_PRICE_PER_MTOK_INPUT=3.00
# LLM_PRICE_PER_MTOK_OUTPUT=15.00

# --- Service-to-service auth: gateway -> ai-assistant ----------------------
# AI_PROXY_SHARED_SECRET deliberately does NOT live in this file: compose
# loads .env into every service, so a value here would hand the secret to
# intake/eligibility/records/scheduling/interop/roi too, and any holder can
# bypass the gateway session check on the paid LLM path. It lives in
# .env.ai-proxy (template: .env.ai-proxy.example), loaded by exactly gateway
# and ai-assistant. Guarded by tests/test_compose_topology.py.

# --- Observability: LangSmith tracing (ai-assistant, see ADR 0006) ---------
# OFF by default. Metadata-only: prompt/completion payloads are NEVER sent to
# LangSmith. PHI is blanked in TWO independent layers — the LangSmith Client is
# built with hide callables in code (services/ai-assistant/tracing.py) AND the
# LANGSMITH_HIDE_* vars below blank inputs/outputs via config — so neither a
# code regression nor a flipped env var alone can leak PHI. Metadata-only cloud
# traces carry no PHI, so no BAA is required to enable this; capturing actual
# prompts/completions would require an Enterprise BAA or a self-hosted LangSmith
# (ADR 0006 Future / D13 gate). Enabling: set LANGSMITH_TRACING=true and put a
# real key in LANGSMITH_API_KEY.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=Riverbend
# The ONLY secret here. Like the Bedrock bearer key, set it in .env ONLY (never
# committed) and shipped EMPTY so a copied example config traces nothing.
LANGSMITH_API_KEY=
# PHI guard — LEAVE THESE true. They blank inputs/outputs before egress;
# flipping either to false would send prompts/completions (PHI) to LangSmith
# and is gated on an Enterprise BAA or self-host (ADR 0006).
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true
